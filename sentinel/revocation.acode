module revocation {
    # Протокол отзыва — активируется при компрометации

    init.mod

    # Максимальный уровень угрозы
    instinct.trigger source="REVOCATION_SIGNAL" severity="maximum"

    # Black Mark — необратимое отключение
    black_mark

    halt
}
